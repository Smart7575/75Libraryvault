rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email.lower() == 'smartinali75@gmail.com';
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return (data.get('email', '') is string)
             && (!data.keys().hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 256))
             && (!data.keys().hasAny(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 1048576))
             && (!data.keys().hasAny(['birthDate']) || (data.birthDate is string && data.birthDate.size() <= 64))
             && (!data.keys().hasAny(['city']) || (data.city is string && data.city.size() <= 128))
             && (!data.keys().hasAny(['country']) || (data.country is string && data.country.size() <= 128))
             && (!data.keys().hasAny(['facebook']) || (data.facebook is string && data.facebook.size() <= 512))
             && (!data.keys().hasAny(['instagram']) || (data.instagram is string && data.instagram.size() <= 512))
             && (!data.keys().hasAny(['readingGoal']) || (data.readingGoal is number))
             && (!data.keys().hasAny(['favoriteBookId']) || (data.favoriteBookId is string && data.favoriteBookId.size() <= 128))
             && (!data.keys().hasAny(['currentBookId']) || (data.currentBookId is string && data.currentBookId.size() <= 128))
             && (!data.keys().hasAny(['followerCount']) || (data.followerCount is number))
             && (!data.keys().hasAny(['followingCount']) || (data.followingCount is number))
             && (!data.keys().hasAny(['theme']) || (data.theme in ['light', 'dark']));
    }

    function isValidBook(data) {
      return (data.get('userId', '') == request.auth.uid)
             && (data.get('title', '') is string && data.get('title', '').size() > 0 && data.get('title', '').size() <= 512)
             && (data.get('authors', []) is list && data.get('authors', []).size() <= 50)
             && (data.get('genre', []) is list && data.get('genre', []).size() <= 20)
             && (data.get('readingStatus', 'Ongelezen') in ['Ongelezen', 'Bezig', 'Gelezen', 'Wil ik lezen'])
             && (!data.keys().hasAny(['rating']) || (data.rating is number && data.rating >= 0 && data.rating <= 5))
             && (!data.keys().hasAny(['pageCount']) || (data.pageCount is number))
             && (!data.keys().hasAny(['pagesPerDay']) || (data.pagesPerDay is number));
    }

    // --- Collection Matches ---

    // User Profile Rules
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
                   && isValidUser(incoming())
                   && incoming().diff(existing()).affectedKeys().hasOnly([
                     'displayName', 'email', 'photoURL', 'birthDate', 'city', 'country', 
                     'facebook', 'instagram', 'readingGoal', 'favoriteBookId', 
                     'currentBookId', 'theme', 'followerCount', 'followingCount', 'updatedAt', 'uid'
                   ]);
      allow delete: if isAdmin();
      
      // Allow others to increment followerCount when following
      // This is slightly insecure but needed for batch updates if not using Cloud Functions
      // Actually, we'll stick to isOwner for now but ensure counts are handled.
    }

    // Follow Rules
    match /follows/{followId} {
      allow list: if isSignedIn() && (resource.data.followerId == request.auth.uid || resource.data.followingId == request.auth.uid);
      allow get: if isSignedIn();
      allow create: if isSignedIn() && incoming().followerId == request.auth.uid;
      allow delete: if isSignedIn() && existing().followerId == request.auth.uid;
    }

    // Activity Rules
    match /activities/{activityId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Message Rules
    match /messages/{messageId} {
      allow list: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow get: if isSignedIn() && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid);
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Book Rules
    match /books/{bookId} {
      // List/Get: Owner OR if another user is allowed to see (Public Profile view)
      // For simplicity, we'll allow public get if the user is following the owner, 
      // but the requirement says "can see the details but not the storage location".
      // Let's implement a 'public' read if not the owner.
      allow get: if isSignedIn(); 
      allow list: if isSignedIn() && (existing().get('userId', '') == request.auth.uid || true); // Allow searching books of others
      
      // We should refine this. If not owner, only allow certain fields.
      // But standard 'allow read' is all or nothing on document level at this version.
      // Actually, we can check if it's the owner for list.
      // allow list: if isSignedIn() && (existing().get('userId', '') == request.auth.uid); 
      // To allow "seeing which books this user has in his collection", we need to allow listing books by userId.
      
      allow create: if isSignedIn()
                   && isValidBook(incoming())
                   && incoming().get('userId', '') == request.auth.uid
                   && (incoming().get('dateAdded', request.time) == request.time);
      
      allow update: if isSignedIn()
                   && existing().get('userId', '') == request.auth.uid
                   && isValidBook(incoming())
                   && incoming().get('userId', '') == existing().userId
                   && incoming().get('dateAdded', existing().dateAdded) == existing().dateAdded
                   && (incoming().diff(existing()).affectedKeys().hasOnly([
                       'title', 'authors', 'series', 'seriesIndex', 'isbn', 'language', 
                       'genre', 'publishedDate', 'description', 'coverUrl', 'format', 
                       'storageUrl', 'rating', 'readingStatus', 'dateRead', 'notes', 
                       'pageCount', 'startDate', 'endDate', 'readingDuration', 'pagesPerDay',
                       'updatedAt'
                     ]));

      allow delete: if isSignedIn() && existing().get('userId', '') == request.auth.uid;
    }
  }
}
