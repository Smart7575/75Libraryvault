{
  "entities": {
    "Book": {
      "title": "Book",
      "description": "A book in the user's personal digital library.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the owner." },
        "title": { "type": "string", "description": "Title of the book." },
        "authors": { "type": "array", "description": "List of authors." },
        "series": { "type": "string", "description": "Series name." },
        "seriesIndex": { "type": "integer", "description": "Index in the series." },
        "isbn": { "type": "string", "description": "ISBN-10 or ISBN-13." },
        "language": { "type": "string", "description": "Language code (e.g. 'nl', 'en')." },
        "genre": { "type": "array", "description": "Genres associated with the book." },
        "publishedDate": { "type": "string", "description": "Publication date string." },
        "description": { "type": "string", "description": "Book summary/description." },
        "coverUrl": { "type": "string", "description": "URL to the cover image." },
        "summary": { "type": "string", "description": "Short summary of the book." },
        "format": { "type": "string", "description": "File format (epub, pdf, etc.)" },
        "storageUrl": { "type": "string", "description": "Link to the file storage (OneDrive, NAS, etc.)" },
        "rating": { "type": "number", "description": "User rating (1-5)." },
        "readingStatus": { "type": "string", "enum": ["Ongelezen", "Bezig", "Gelezen", "Wil ik lezen"] },
        "dateAdded": { "type": "string", "format": "date-time" },
        "dateRead": { "type": "string", "format": "date-time" },
        "notes": { "type": "string", "description": "Personal notes or review." },
        "pageCount": { "type": "integer", "description": "Totaal aantal pagina's." },
        "startDate": { "type": "string", "format": "date-time", "description": "Datum waarop gestart is met lezen." },
        "endDate": { "type": "string", "format": "date-time", "description": "Datum waarop het boek uitgelezen is." },
        "readingDuration": { "type": "integer", "description": "Aantal dagen over het lezen gedaan." },
        "pagesPerDay": { "type": "number", "description": "Gemiddeld aantal pagina's per dag." },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User specific settings and metadata.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "birthDate": { "type": "string", "description": "Geboortedatum" },
        "city": { "type": "string", "description": "Woonplaats" },
        "country": { "type": "string", "description": "Land woonplaats" },
        "facebook": { "type": "string" },
        "instagram": { "type": "string" },
        "readingGoal": { "type": "integer", "description": "Leesdoel per jaar" },
        "favoriteBookId": { "type": "string", "description": "ID of the favorite book" },
        "currentBookId": { "type": "string", "description": "ID of the book currently being read" },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "followerCount": { "type": "integer", "default": 0 },
        "followingCount": { "type": "integer", "default": 0 }
      }
    },
    "Follow": {
      "title": "Follow",
      "description": "Represents a follow relationship between two users.",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followingId"]
    },
    "Activity": {
      "title": "Activity",
      "description": "A social post generated by user actions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "type": { "type": "string", "enum": ["START_READING", "FINISH_READING", "RATE_BOOK"] },
        "bookId": { "type": "string" },
        "bookTitle": { "type": "string" },
        "bookCover": { "type": "string" },
        "rating": { "type": "number" },
        "review": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message between two users, optionally sharing a book location.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "bookId": { "type": "string", "description": "Optional shared book ID" },
        "bookTitle": { "type": "string", "description": "Optional shared book Title" },
        "storageUrl": { "type": "string", "description": "Optional shared storage location" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverId", "text", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile and settings."
    },
    "follows/{followId}": {
      "schema": "Follow",
      "description": "Follow relationships."
    },
    "activities/{activityId}": {
      "schema": "Activity",
      "description": "Social activity feed."
    },
    "messages/{messageId}": {
      "schema": "Message",
      "description": "Direct messages between users."
    },
    "books/{bookId}": {
      "schema": "Book",
      "description": "Bibliographic and personal book records."
    }
  }
}
